# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# In Expo, public env vars must start with EXPO_PUBLIC_

# Supabase — from your project's Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Google sign-in — from Google Cloud Console > Credentials (OAuth 2.0 Client IDs).
# WEB client ID is the OAuth audience Supabase validates (used on iOS AND Android).
# iOS client ID is needed for the native iOS Google flow.
# See doc/social-signin-setup.md for the full walkthrough.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com
