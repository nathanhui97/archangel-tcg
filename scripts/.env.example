# Server-only environment for the seed scripts. Copy to scripts/.env and fill in.
# These keys NEVER appear in the mobile app bundle.

# Same project URL as the app's EXPO_PUBLIC_SUPABASE_URL
SUPABASE_URL=https://your-project.supabase.co

# SERVICE-ROLE KEY — full admin access. NEVER expose to the client.
# Find at: Supabase dashboard > Settings > API > Project API keys > service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ANON / PUBLISHABLE KEY — same one your app uses (EXPO_PUBLIC_SUPABASE_ANON_KEY).
# Required by the smoke test (it signs in AS users to verify RLS).
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxx
